    {
        "id": "fn_write_alerts",
        "type": "function",
        "z": "739bcde6ba837444",
        "name": "Write Pending Alerts",
        "func": "const pending = flow.get('pendingAlerts') || [];\nif (pending.length === 0) return null;\n// Send them one at a time by returning an array of messages\nreturn [pending[0]];\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1050,
        "y": 160,
