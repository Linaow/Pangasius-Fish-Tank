    {
        "id": "fn_query_history",
        "type": "function",
        "z": "739bcde6ba837444",
        "name": "Query History",
        "func": "// ?range=1h|6h|24h|7d — defaults to 1h\nconst range = (msg.req.query.range || '1h');\nconst intervals = { '1h':'1 hour', '6h':'6 hours', '24h':'24 hours', '7d':'7 days' };\nconst since = intervals[range] || '1 hour';\n\nmsg.topic = `\n  SELECT ts, temp, tds, turbidity, species\n  FROM sensor_readings\n  WHERE ts >= datetime('now', '-${since}')\n  ORDER BY ts ASC\n  LIMIT 500;\n`;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
