    {
        "id": "fn_build_csv",
        "type": "function",
        "z": "739bcde6ba837444",
        "name": "Build CSV",
        "func": "const rows = msg.payload || [];\nlet csv = 'timestamp,temperature_C,tds_ppm,turbidity_NTU,species\\n';\nrows.forEach(r => {\n  csv += `${r.ts},${r.temp},${r.tds},${r.turbidity},${r.species}\\n`;\n});\nmsg.payload = csv;\nmsg.headers = {\n  'Access-Control-Allow-Origin': '*',\n  'Content-Type': 'text/csv',\n  'Content-Disposition': `attachment; filename=\"aquarium_${msg._csvRange || '24h'}.csv\"`\n};\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
