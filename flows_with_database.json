    {
        "id": "fn_respond_esp",
        "type": "function",
        "z": "739bcde6ba837444",
        "name": "Build ESP32 Response",
        "func": "const actuatorState = global.get('actuatorState') || { heat: false, filter: false, air: false };\nmsg.payload = { heat: actuatorState.heat, filter: actuatorState.filter, air: actuatorState.air };\nmsg.statusCode = 200;\nmsg.headers = { 'Content-Type': 'application/json', 'Access-Control-Allow-Origin': '*' };\nreturn msg;",
