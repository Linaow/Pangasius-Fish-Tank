    {
        "id": "fn_init_db",
        "type": "function",
        "z": "739bcde6ba837444",
        "name": "Create Tables",
        "func": "// Create all three tables if they don't exist yet\nmsg.topic = `\n  CREATE TABLE IF NOT EXISTS sensor_readings (\n    id        INTEGER PRIMARY KEY AUTOINCREMENT,\n    ts        DATETIME DEFAULT CURRENT_TIMESTAMP,\n    temp      REAL,\n    tds       REAL,\n    turbidity REAL,\n    species   TEXT\n  );\n  CREATE TABLE IF NOT EXISTS actuator_history (\n    id        INTEGER PRIMARY KEY AUTOINCREMENT,\n    ts        DATETIME DEFAULT CURRENT_TIMESTAMP,\n    heat      INTEGER,\n    filter    INTEGER,\n    air       INTEGER,\n    species   TEXT\n  );\n  CREATE TABLE IF NOT EXISTS system_alerts (\n    id        INTEGER PRIMARY KEY AUTOINCREMENT,\n    ts        DATETIME DEFAULT CURRENT_TIMESTAMP,\n    level     TEXT,\n    message   TEXT,\n    species   TEXT\n  );\n`;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 60,
        "wires": [["sqlite_db_node"]]
    },

