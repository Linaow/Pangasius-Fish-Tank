    {
        "id": "fn_save_sensor",
        "type": "function",
        "z": "739bcde6ba837444",
        "name": "Store Sensors + Check Alerts",
        "func": "// --- 1. Save sensor data to memory (existing behaviour) ---\nglobal.set('sensorData', msg.payload);\n\nconst d = msg.payload;\nconst species = flow.get('selectedFish') || 'tilapia';\n\n// --- 2. Save to SQLite ---\nmsg.topic = `INSERT INTO sensor_readings (temp, tds, turbidity, species)\n  VALUES (${parseFloat(d.temp)||0}, ${parseFloat(d.tds)||0}, ${parseFloat(d.turbidity)||0}, '${species}');`;\n\n// --- 3. Alert thresholds per species ---\nconst thresholds = {\n  tilapia:    { tempMin:20, tempMax:32, tdsMax:600, turbMax:150 },\n  pangasius:  { tempMin:22, tempMax:30, tdsMax:500, turbMax:200 },\n  zebra_fish: { tempMin:20, tempMax:28, tdsMax:400, turbMax:100 }\n};\nconst thr = thresholds[species] || thresholds.tilapia;\nconst alerts = [];\n\nif (d.temp < thr.tempMin) alerts.push({ level:'WARNING', message:`Temperature too low: ${d.temp.toFixed(1)}°C (min ${thr.tempMin}°C)` });\nif (d.temp > thr.tempMax) alerts.push({ level:'CRITICAL', message:`Temperature too high: ${d.temp.toFixed(1)}°C (max ${thr.tempMax}°C)` });\nif (d.tds  > thr.tdsMax)  alerts.push({ level:'WARNING', message:`TDS too high: ${Math.round(d.tds)}ppm (max ${thr.tdsMax}ppm)` });\nif (d.turbidity > thr.turbMax) alerts.push({ level:'CRITICAL', message:`Turbidity critical: ${d.turbidity.toFixed(1)}NTU (max ${thr.turbMax}NTU)` });\n\n// Store pending alerts so the follow-up function can write them after the sensor insert\nflow.set('pendingAlerts', alerts.map(a => ({\n  topic: `INSERT INTO system_alerts (level, message, species) VALUES ('${a.level}','${a.message.replace(/'/g,\"''\")}','${species}');`\n})));\n\n// Build response immediately so the ESP32 doesn't time out\nconst actuatorState = global.get('actuatorState') || { heat: false, filter: false, air: false };\nmsg.res_payload = { heat: actuatorState.heat, filter: actuatorState.filter, air: actuatorState.air };\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 590,
        "y": 180,
        "wires": [["sqlite_write_sensor"]]
    },
