    {
        "id": "fn_query_csv",
        "type": "function",
        "z": "739bcde6ba837444",
        "name": "Query CSV Export",
        "func": "const range = (msg.req.query.range || '24h');\nconst intervals = { '1h':'1 hour', '6h':'6 hours', '24h':'24 hours', '7d':'7 days' };\nconst since = intervals[range] || '24 hours';\nmsg._csvRange = range;\n\nmsg.topic = `\n  SELECT ts, temp, tds, turbidity, species\n  FROM sensor_readings\n  WHERE ts >= datetime('now','-${since}')\n  ORDER BY ts ASC;\n`;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
