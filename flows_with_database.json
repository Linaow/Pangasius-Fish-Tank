    {
        "id": "a4ee6c51198e544a",
        "type": "function",
        "z": "739bcde6ba837444",
        "name": "Build /get-data Response",
        "func": "let rawSensors = global.get('sensorData') || {};\nlet sensorData = (typeof rawSensors === 'string') ? JSON.parse(rawSensors) : rawSensors;\nlet aiData = flow.get('aiData') || { detected_species:'Waiting...', count:0, avg_size:'0cm' };\nlet selectedFish = flow.get('selectedFish') || 'tilapia';\nconst actuatorState = global.get('actuatorState') || { heat:false, filter:false, air:false };\n\nconst fishSettings = {\n  tilapia:    { temp:28, tds:600 },\n  pangasius:  { temp:26, tds:400 },\n  zebra_fish: { temp:24, tds:200 }\n};\n\nmsg.payload = {\n  sensors: {\n    temp:      parseFloat(sensorData.temp)      || 0,\n    tds:       parseFloat(sensorData.tds)       || 0,\n    turbidity: parseFloat(sensorData.turbidity) || 0\n  },\n  actuators: actuatorState,\n  ai: aiData,\n  settings: fishSettings[selectedFish]\n};\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
